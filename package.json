{
  "name": "island",
  "version": "1.0.0",
  "description": "Your island. Your rules. Your freedom.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.omarbouzganda.island",
    "productName": "Island",
    "icon": "assets/logo.png",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "assets/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo.png",
      "category": "Network"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo.png"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "author": "Omar Bouzganda <https://github.com/omarbouzganda>",
  "license": "MIT"
}
